{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Spotify": {
    "ClientId": "YOUR_SPOTIFY_CLIENT_ID",
    "ClientSecret": "YOUR_SPOTIFY_CLIENT_SECRET",
    // Port used by the embedded OAuth callback server (EmbedIOAuthServer).
    // Must match the redirect URI registered in your Spotify developer app.
    // Use a port that is NOT the same as this web app's listening port (default: 5077).
    "RedirectUri": "http://localhost:5000/callback"
  }
}
